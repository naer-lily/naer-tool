{
  "name": "futari",
  "version": "0.1.1",
  "description": "Futari - Plugin-based command launcher",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "vue-tsc --noEmit --project tsconfig.web.json && vue-tsc --noEmit --project tsconfig.node.json",
    "package": "electron-vite build && electron-builder --win portable"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "electron-log": "^5.4.4",
    "vue": "^3.4.38"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.4",
    "vue-tsc": "^2.0.29"
  },
  "build": {
    "appId": "com.futari.app",
    "productName": "Futari",
    "icon": "resources/icon.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "asar": false,
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "Futari-${version}-portable.exe"
    }
  }
}
